FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    chainlit==1.1.0 \
    httpx==0.27.0 \
    pydantic==2.7.1 \
    python-dotenv==1.0.1

COPY chainlit_app.py /app/chainlit_app.py

ENV CHAINLIT_HOST=0.0.0.0
ENV CHAINLIT_PORT=8080

EXPOSE 8080

CMD ["chainlit", "run", "chainlit_app.py", "--host", "0.0.0.0", "--port", "8080", "--headless"]
