# =============================================================================
# AgentOS – Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in all required values.
# Lines beginning with # are comments.
# Never commit .env to version control.
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=AgentOS
APP_ENV=development                        # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR

# =============================================================================
# DATABASE – PostgreSQL 16
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=agentos
POSTGRES_PASSWORD=agentos_secret          # CHANGE IN PRODUCTION
POSTGRES_DB=agentos
LANGFUSE_DB=langfuse                       # Secondary DB created at init

# Full DSN (used by SQLAlchemy / Alembic)
DATABASE_URL=postgresql+asyncpg://agentos:agentos_secret@postgres:5432/agentos

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret               # CHANGE IN PRODUCTION
REDIS_DB=0
REDIS_MAX_MEMORY=512mb
REDIS_URL=redis://:redis_secret@redis:6379/0

# Celery uses Redis as broker and backend
CELERY_BROKER_URL=redis://:redis_secret@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redis_secret@redis:6379/1
CELERY_LOG_LEVEL=info
CELERY_CONCURRENCY=4

# =============================================================================
# MINIO – S3-Compatible Object Storage
# =============================================================================
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret     # CHANGE IN PRODUCTION
MINIO_SECURE=false                         # true in production with TLS
MINIO_REGION=us-east-1
MINIO_UPLOADS_BUCKET=uploads
MINIO_ARTIFACTS_BUCKET=artifacts
MINIO_REPORTS_BUCKET=reports

# AWS-compatible env vars (used by boto3/s3fs)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin_secret
AWS_ENDPOINT_URL=http://minio:9000
AWS_DEFAULT_REGION=us-east-1

# =============================================================================
# LLM API KEYS
# =============================================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...                     # Required for GPT-4o routing
OPENAI_ORG_ID=                            # Optional organization ID
OPENAI_API_BASE=https://api.openai.com/v1

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...              # Required for Claude routing

# --- Google Gemini ---
GEMINI_API_KEY=AIza...                    # Optional – Gemini Pro routing

# --- Groq (fast inference) ---
GROQ_API_KEY=gsk_...                      # Optional – Llama via Groq

# --- Mistral AI ---
MISTRAL_API_KEY=...                        # Optional – Mistral routing

# --- Cohere ---
COHERE_API_KEY=...                         # Optional

# --- Together AI ---
TOGETHER_API_KEY=...                       # Optional – open source models

# --- Azure OpenAI (alternative to direct OpenAI) ---
# AZURE_API_KEY=...
# AZURE_API_BASE=https://YOUR-RESOURCE.openai.azure.com
# AZURE_API_VERSION=2024-02-01
# AZURE_DEPLOYMENT_NAME=gpt-4o

# =============================================================================
# MODEL ROUTING VARIABLES
# =============================================================================
# These control which model alias maps to which provider/model.
# The LiteLLM proxy exposes these as unified endpoints.

# Orchestrator (complex reasoning, multi-step planning)
ORCHESTRATOR_MODEL=claude-sonnet-4-5
ORCHESTRATOR_MAX_TOKENS=8192
ORCHESTRATOR_TEMPERATURE=0.1

# Analyst (code generation, data analysis)
ANALYST_MODEL=gpt-4o
ANALYST_MAX_TOKENS=4096
ANALYST_TEMPERATURE=0.0

# Fast model (classification, routing decisions, short tasks)
FAST_MODEL=groq/llama-3.1-8b-instant
FAST_MAX_TOKENS=1024
FAST_TEMPERATURE=0.0

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Vision model (chart/image understanding)
VISION_MODEL=gpt-4o

# Local model via Ollama (offline / privacy mode)
LOCAL_MODEL=ollama/mistral:7b-instruct
LOCAL_MODEL_BASE_URL=http://ollama:11434

# Fallback chain order (comma-separated model aliases)
FALLBACK_CHAIN=gpt-4o,claude-sonnet-4-5,groq/llama-3.1-70b-versatile

# =============================================================================
# LITELLM PROXY
# =============================================================================
LITELLM_BASE_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-litellm-master-key-change-me
LITELLM_SALT_KEY=sk-litellm-salt-change-me
LITELLM_LOG_LEVEL=INFO
LITELLM_REQUEST_TIMEOUT=120
LITELLM_MAX_RETRIES=3

# Budget limits (USD per month, 0 = unlimited)
LITELLM_MONTHLY_BUDGET=0
LITELLM_MAX_BUDGET_PER_REQUEST=0.50

# =============================================================================
# LANGFUSE – LLM Observability
# =============================================================================
LANGFUSE_URL=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-...             # Get from Langfuse UI
LANGFUSE_SECRET_KEY=sk-lf-...             # Get from Langfuse UI
LANGFUSE_HOST=http://langfuse-server:3000 # Internal service address
LANGFUSE_NEXTAUTH_SECRET=changeme-langfuse-secret-32chars-min
LANGFUSE_FLUSH_AT=15
LANGFUSE_FLUSH_INTERVAL=1000
LANGFUSE_ENABLED=true                      # Set false to disable tracing

# =============================================================================
# CHAINLIT UI
# =============================================================================
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8080
CHAINLIT_AUTH_SECRET=chainlit-auth-secret-change-me
# OAuth (optional)
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
CHAINLIT_MAX_SIZE_MB=50                    # Max file upload size
CHAINLIT_SESSION_TIMEOUT=3600             # Seconds

# =============================================================================
# FRONTEND (React/Vite)
# =============================================================================
VITE_API_BASE_URL=http://localhost:8000
VITE_CHAINLIT_URL=http://localhost:8080
VITE_LANGFUSE_URL=http://localhost:3001
VITE_APP_TITLE=AgentOS

# =============================================================================
# SANDBOX – Docker-in-Docker code execution
# =============================================================================
SANDBOX_IMAGE=agentos-sandbox:latest
SANDBOX_TIMEOUT=30                         # Seconds before sandbox kill
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1.0
SANDBOX_NETWORK=none                       # Sandboxes run isolated (no internet)
SANDBOX_WORKING_DIR=/home/sandbox/workspace

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_OLLAMA=true                         # Enable local Ollama models
ENABLE_LANGFUSE=true                       # Enable LLM tracing
ENABLE_SANDBOX=true                        # Enable Docker code sandbox
ENABLE_FILE_UPLOADS=true
ENABLE_SCHEDULED_REPORTS=true
ENABLE_A2A=true                            # Agent-to-Agent protocol
ENABLE_MEMORY=true                         # Persistent agent memory
ENABLE_MULTI_MODAL=true                    # Image/chart understanding

# =============================================================================
# PARALLELISM & PERFORMANCE
# =============================================================================
MAX_PARALLEL_JOBS=8                        # Max concurrent pipeline jobs
MAX_PARALLEL_AGENTS=4                      # Max concurrent agent sub-tasks
AGENT_STEP_TIMEOUT=300                     # Seconds per agent step
PIPELINE_TIMEOUT=1800                      # Seconds for full pipeline
HTTP_TIMEOUT=60
HTTP_MAX_CONNECTIONS=100

# =============================================================================
# SECURITY
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_HOSTS=localhost,127.0.0.1
JWT_SECRET_KEY=jwt-secret-change-me-to-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440                    # 24 hours
API_KEY_HEADER=X-API-Key

# =============================================================================
# CELERY FLOWER (monitoring UI)
# =============================================================================
FLOWER_BASIC_AUTH=admin:flower_secret     # user:password

# =============================================================================
# OLLAMA (local inference)
# =============================================================================
OLLAMA_HOST=http://ollama:11434
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_KEEP_ALIVE=5m
# Comma-separated list of models to pull on startup
OLLAMA_PRELOAD_MODELS=mistral:7b-instruct,nomic-embed-text

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================
AGENT_CONFIG_ROOT=/app/agent-config
AGENT_FS_ROOT=/app/agent-config
SOUL_FILE=agent-config/soul.md
MEMORY_PATH=agent-config/memory
SKILLS_PATH=agent-config/skills
KNOWLEDGE_PATH=agent-config/knowledge
PIPELINES_PATH=agent-config/pipelines

# Memory update frequency
MEMORY_FLUSH_AFTER_N_RUNS=1               # Update memory after every run

# =============================================================================
# REPORTING
# =============================================================================
REPORT_OUTPUT_FORMAT=html,pdf,json        # Comma-separated
REPORT_TIMEZONE=America/New_York
FISCAL_YEAR_START_MONTH=10               # October (fiscal year Oct 1 – Sep 30)
DEFAULT_CURRENCY=USD

# Distribution (comma-separated email addresses)
REPORT_DISTRIBUTION_LIST=finance@example.com,cfo@example.com
SMTP_HOST=                                 # Optional SMTP for email delivery
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=agentos@example.com
